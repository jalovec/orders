{% extends 'base.html.twig' %}

{% block title %}Orders{% endblock %}

{% block body %}


    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>
    <center>
        <FORM action="/orders" method="{{ method }}">
        <TABLE width="70%" border="1">
            <tr>
                <td width="100%" colspan="2"><font face='Arial' size='5'>Order create</font></td>
            </tr>
            {% if method is same as('post') %}
                <tr>
                    <th>Customer Name</th>
                    <td><INPUT type="text" name="customerName" id="customerName" value="{% if order is defined %}{{ order.customerName }}{% endif %}"></td>
                </tr>
            {% endif %}
            {% if method is same as('put') %}
                <tr>
                    <th>Status</th>
                    <td><INPUT type="text" name="status" id="status" value="{% if order is defined %}{{ order.staus.value }}{% endif %}"></td>
                </tr>
            {% endif %}
            <tr>
                <th>Total price</th>
                <td><INPUT type="text" name="totalPrice" id="totalPrice" value="{% if order is defined %}{{ order.totalPrice }}{% endif %}"> CZK</td>
            </tr>
            <tr>
                <th>&nbsp;</th>
                <td>
                    {% if order is defined %}
                    <INPUT type="hidden" name="id" value="{{ order.id }}">
                    {% endif %}
                    <INPUT type="submit" name="submitOrder" id="submitOrder" value="CREATE ORDER">
                </td>
            </tr>
        </TABLE>
        </FORM>
    </center>
{% endblock %}
